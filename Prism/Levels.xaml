<Window x:Class="Prism.Levels"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Title="Levels" Height="398" Width="520"
        Background="#3a3a3a">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="49*"/>
            <ColumnDefinition Width="331*"/>
            <ColumnDefinition Width="120"/>
        </Grid.ColumnDefinitions>

        <!-- CONTENUTO SINISTRA -->
        <StackPanel Grid.ColumnSpan="2">

            <!-- Preset -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                <TextBlock Text="Preset:" Foreground="White" VerticalAlignment="Center"/>
                <ComboBox Width="311" Margin="10,0,0,0">
                    <ComboBoxItem Content="Personale"/>
                </ComboBox>
            </StackPanel>

            <!-- Canale -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                <TextBlock Text="Canale:" Foreground="White" VerticalAlignment="Center"/>
                <ComboBox Width="100" Margin="10,0,0,0">
                    <ComboBoxItem Content="RGB"/>
                </ComboBox>
            </StackPanel>

            <!-- INPUT LEVELS -->
            <GroupBox Header="Input:" Foreground="White" Margin="0,0,0,10">
                <StackPanel Margin="5">

                    <!-- Istogramma -->
                    <Border Background="#1e1e1e" Height="120" CornerRadius="2">
                        <Canvas x:Name="miniCanvas" Width="320" Height="120"/>
                    </Border>

                    <!-- Slider -->

                    <!-- Valori -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Label Content="Shadows" VerticalAlignment="Center"/>
                        <TextBox x:Name="InputBlack" Width="40" Text="0" Margin="5" Style="{DynamicResource ParameterStyle}" TextChanged="TextBox_TextChanged"/>
                        <Label Content="Midtones" VerticalAlignment="Center"/>
                        <TextBox x:Name="InputMidtones" Width="50" Text="0" Margin="5" Style="{DynamicResource ParameterStyle}" TextChanged="TextBox_TextChanged"/>
                        <Label Content="Gamma" VerticalAlignment="Center"/>
                        <TextBox x:Name="InputGamma" Width="40" Text="0" Margin="5" Style="{DynamicResource ParameterStyle}" TextChanged="TextBox_TextChanged"/>
                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <!-- OUTPUT LEVELS -->
            <GroupBox Header="Output:" Foreground="White">
                <StackPanel Margin="5">

                    <!-- Gradient -->
                    <Rectangle Height="20">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Black" Offset="0"/>
                                <GradientStop Color="White" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Slider -->

                    <!-- Valori -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Label Content="Shadows" VerticalAlignment="Center"/>
                        <TextBox x:Name="OutputBlack" Width="40" Text="0" Margin="5" Style="{DynamicResource ParameterStyle}" TextChanged="TextBox_TextChanged"/>
                        <Label Content="Lights" VerticalAlignment="Center"/>
                        <TextBox x:Name="OutputWhite" Width="40" Text="255" Margin="5" Style="{DynamicResource ParameterStyle}" TextChanged="TextBox_TextChanged"/>
                    </StackPanel>

                </StackPanel>
            </GroupBox>

        </StackPanel>

        <!-- COLONNA DESTRA (PULSANTI) -->
        <StackPanel Grid.Column="2" HorizontalAlignment="Left" Margin="10,0,0,0" Width="110">

            <Button Content="OK" Margin="5" Height="30"/>
            <Button Content="Cancel" Margin="5" Height="30" Click="Button_Click"/>

        </StackPanel>

    </Grid>
</Window>