<mah:MetroWindow
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Prism.MainWindow"
        Title="Prism"
        Height="850" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Lab.Brush.Background}"
   >

    <mah:MetroWindow.Resources>

        <Color x:Key="Color.Background">#1C1C1C</Color>
        <Color x:Key="Color.Panel">#2A2A2A</Color>
        <Color x:Key="Color.PanelRaised">#333333</Color>
        <Color x:Key="Color.PanelSunken">#1A1A1A</Color>
        <Color x:Key="Color.Text">#D4D4D4</Color>
        <Color x:Key="Color.MutedText">#888888</Color>
        <Color x:Key="Color.Accent">#4A7AB5</Color>
        <Color x:Key="Color.AccentSoft">#7AAA7A</Color>
        <Color x:Key="Color.TitleBarStart">#2C3A52</Color>
        <Color x:Key="Color.TitleBarEnd">#1A2840</Color>


        <!-- ══════════════════════════════════════════ -->
        <!-- MENU                                       -->


        <!-- ══════════════════════════════════════════ -->
        <!-- TOOLBAR                                    -->


        <!-- ══════════════════════════════════════════ -->
        <!-- SLIDERS                                    -->


        <!-- ══════════════════════════════════════════ -->
        <!-- SIDEBAR UI                                 -->
        <!-- Shadows per effetto Platinum rilievo -->
        <Color x:Key="Color.ShadowLight">#444444</Color>
        <Color x:Key="Color.ShadowDark">#111111</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="Brush.Background"   Color="{StaticResource Color.Background}"/>
        <SolidColorBrush x:Key="Brush.Panel"        Color="{StaticResource Color.Panel}"/>
        <SolidColorBrush x:Key="Brush.PanelRaised"  Color="{StaticResource Color.PanelRaised}"/>
        <SolidColorBrush x:Key="Brush.PanelSunken"  Color="{StaticResource Color.PanelSunken}"/>
        <SolidColorBrush x:Key="Brush.Text"         Color="{StaticResource Color.Text}"/>
        <SolidColorBrush x:Key="Brush.MutedText"    Color="{StaticResource Color.MutedText}"/>
        <SolidColorBrush x:Key="Brush.Accent"       Color="{StaticResource Color.Accent}"/>
        <SolidColorBrush x:Key="Brush.AccentSoft"   Color="{StaticResource Color.AccentSoft}"/>
        <SolidColorBrush x:Key="Brush.ShadowLight"  Color="{StaticResource Color.ShadowLight}"/>
        <SolidColorBrush x:Key="Brush.ShadowDark"   Color="{StaticResource Color.ShadowDark}"/>

        <LinearGradientBrush x:Key="Ableton.TitleBar" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="{StaticResource Color.TitleBarStart}" Offset="0"/>
            <GradientStop Color="{StaticResource Color.TitleBarEnd}"   Offset="0.5"/>
            <GradientStop Color="{StaticResource Color.TitleBarStart}" Offset="1"/>
        </LinearGradientBrush>


        <!-- ══════════════════════════════════════════ -->
        <Style x:Key="MenuBarStyle" TargetType="{x:Type Menu}">
            <Setter Property="Background"   Value="{StaticResource Brush.PanelRaised}"/>
            <Setter Property="Foreground"   Value="{StaticResource Brush.Text}"/>
            <Setter Property="FontFamily"   Value="Geneva, Segoe UI, Arial"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Height"       Value="24"/>
            <Setter Property="Padding"      Value="4,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"  Value="{StaticResource Brush.ShadowDark}"/>
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground"       Value="{StaticResource Brush.Text}"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Padding"          Value="10,3"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontFamily"       Value="Geneva, Segoe UI, Arial"/>
            <Setter Property="FontSize"         Value="12"/>

            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Accent}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <!-- ══════════════════════════════════════════ -->
        <Style x:Key="ToolbarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background"       Value="{StaticResource Brush.PanelRaised}"/>
            <Setter Property="Foreground"       Value="{StaticResource Brush.MutedText}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Brush.ShadowLight}"/>
            <Setter Property="Padding"          Value="10,3"/>
            <Setter Property="FontFamily"       Value="Geneva, Segoe UI, Arial"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Height"           Value="22"/>
            <Setter Property="Cursor"           Value="Hand"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E3E"/>
                    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <!-- Simula bevel sunken al clic -->
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.ShadowDark}"/>
                    <Setter Property="Background"  Value="{StaticResource Brush.PanelSunken}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SliderButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Background"       Value="{StaticResource Brush.PanelRaised}"/>
            <Setter Property="Foreground"       Value="{StaticResource Brush.MutedText}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Brush.ShadowLight}"/>
            <Setter Property="Padding"          Value="3"/>
            <Setter Property="FontFamily"       Value="Geneva, Segoe UI, Arial"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Height"           Value="22"/>
            <Setter Property="Cursor"           Value="Hand"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E3E"/>
                    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <!-- Simula bevel sunken al clic -->
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.ShadowDark}"/>
                    <Setter Property="Background"  Value="{StaticResource Brush.PanelSunken}"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <!-- ══════════════════════════════════════════ -->
        <Style x:Key="SliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Foreground"       Value="{StaticResource Brush.Accent}"/>
            <Setter Property="Background"       Value="{StaticResource Brush.PanelSunken}"/>
            <Setter Property="Height"           Value="6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>


        <!-- ══════════════════════════════════════════ -->
        <Style x:Key="SidebarLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground"   Value="{StaticResource Brush.Accent}"/>
            <Setter Property="FontFamily"   Value="Geneva, Segoe UI, Arial"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Margin"       Value="0,10,0,4"/>
        </Style>

        <Style x:Key="SliderValue" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground"       Value="{StaticResource Brush.Accent}"/>
            <Setter Property="FontFamily"       Value="Monaco, Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth"         Value="36"/>
            <Setter Property="TextAlignment"    Value="Right"/>
        </Style>

        <Style x:Key="SidebarSeparator" TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="{StaticResource Brush.ShadowDark}"/>
            <Setter Property="Margin"     Value="0,6,0,0"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground"       Value="{StaticResource Brush.AccentSoft}"/>
            <Setter Property="FontFamily"       Value="Geneva, Segoe UI, Arial"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Margin"           Value="0,14,0,6"/>
        </Style>

    </mah:MetroWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="42*"/>
            <ColumnDefinition Width="23*"/>
            <ColumnDefinition Width="69*"/>
            <ColumnDefinition Width="506*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <!-- Menu -->
            <RowDefinition Height="40"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Contenuto principale -->
            <RowDefinition Height="22"/>
            <!-- Statusbar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- MENU BAR                                -->
        <!-- ═══════════════════════════════════════ -->
        <Menu Grid.Row="0" Grid.ColumnSpan="4" FontSize="12">
            <MenuItem Header="File">
                <MenuItem Header="Open JPEG" Click="onJPGOpen" />
                <MenuItem Header="Import RAW..."         InputGestureText="Ctrl+O" Click="onRAWOpen"/>
                <Separator Background="#333333"/>
                <MenuItem Header="Salva..."           InputGestureText="Ctrl+S"/>
                <MenuItem Header="Export Image..." Click="onExportClick"     InputGestureText="Ctrl+Shift+E" Style="{StaticResource MenuItemStyle}"/>
                <Separator Background="#333333"/>
                <MenuItem Header="Esci"                InputGestureText="Alt+F4" Style="{StaticResource MenuItemStyle}"/>
            </MenuItem>
            <MenuItem Header="Edit" Style="{StaticResource MenuItemStyle}">
                <MenuItem Header="Undo"             InputGestureText="Ctrl+Z" Style="{StaticResource MenuItemStyle}"/>
                <MenuItem Header="Redo"          InputGestureText="Ctrl+Y" Style="{StaticResource MenuItemStyle}"/>
                <Separator Background="#333333"/>
                <MenuItem Header="Reset All"     Style="{StaticResource MenuItemStyle}"/>
            </MenuItem>
            <MenuItem Header="Image" Style="{StaticResource MenuItemStyle}">
                <MenuItem Header="Levels" Click="onLevelsClick"             InputGestureText="Ctrl+Alt+L" Style="{StaticResource MenuItemStyle}"/>
                <MenuItem Header="Resizing" Click="onResizingClick"             InputGestureText="Ctrl+Alt+R" Style="{StaticResource MenuItemStyle}"/>

            </MenuItem>
            <MenuItem Header="View" Style="{StaticResource MenuItemStyle}">
                <MenuItem Header="100%" Click="on100Zoom"        InputGestureText="1" Style="{StaticResource MenuItemStyle}"/>
                <MenuItem Header="Adapt to Window" Click="onAdaptZoom" InputGestureText="F" Style="{StaticResource MenuItemStyle}"/>
                <Separator Background="#333333"/>
                <MenuItem Header="Histogram" Click="onHistogramOpen"   IsCheckable="True" IsChecked="True" Style="{StaticResource MenuItemStyle}"/>
            </MenuItem>
            <MenuItem Header="LUT" Style="{StaticResource MenuItemStyle}">
                <MenuItem Header="Carica LUT .cube..."  Style="{StaticResource MenuItemStyle}"/>
                <MenuItem Header="Rimuovi LUT"          Style="{StaticResource MenuItemStyle}"/>
            </MenuItem>
            <MenuItem Header="Aiuto" Style="{StaticResource MenuItemStyle}">
                <MenuItem Header="Informazioni su Wakame Studio" Style="{StaticResource MenuItemStyle}"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════════════════════ -->
        <!-- TOOLBAR                                 -->
        <!-- ═══════════════════════════════════════ -->

        <Border Grid.Row="1" Grid.ColumnSpan="4" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="0,1,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">

                <Button Style="{StaticResource ToolbarButtonStyle}" 
            Width="28" Height="28" Padding="0"
            Click="onImageAlign">
                    <Image Source="Icons/img-align.png" Width="16" Height="16"/>
                </Button>
                <Separator Width="1" Background="#333333" Margin="4,6"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
            Width="28" Height="28" Padding="0" Click="onCropImg">
                    <Image Source="Icons/img-crop.png" Width="16" Height="16"/>
                </Button>
                <Separator Width="3" Background="#333333" Margin="4,6"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                    Width="28" Height="28" Padding="0"/>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- CONTENUTO PRINCIPALE                    -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="2" Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Area immagine -->
                <ColumnDefinition Width="5"/>
                <!-- Splitter -->
                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="400"/>
                <!-- Sidebar -->
            </Grid.ColumnDefinitions>

            <!-- AREA PREVIEW IMMAGINE -->
            <Border Grid.Column="0" Background="#141414">
                
                <Grid>
                    <!-- Griglia di sfondo (pattern scacchiera) -->
                    <Border Background="#1A1A1A"/>

                    <!-- Istogramma overlay (in basso a sinistra) -->
                    <!-- Placeholder quando nessuna immagine è aperta -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                x:Name="DropZone"/>

                    <!-- Immagine principale (nascosta finché non si apre un file) -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent"
                                  Visibility="Collapsed"
                                  x:Name="ImageScrollViewer">
                        <Grid>
                        <Image x:Name="PreviewImage"
                               Stretch="None"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               PreviewMouseWheel="PreviewImage_PreviewMouseWheel">

                            <Image.RenderTransform>
                                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                            </Image.RenderTransform>

                        </Image>

                            <Canvas x:Name="CropCanvas"
                Background="Transparent"
                Visibility="Collapsed"
                MouseLeftButtonDown="CropCanvas_MouseDown"
                MouseMove="CropCanvas_MouseMove"
                MouseLeftButtonUp="CropCanvas_MouseUp">
                                <Border x:Name="CropToast"
        Background="#CC000000"
        CornerRadius="4"
        Padding="8,4"
        Visibility="Collapsed"
        IsHitTestVisible="False"
        Panel.ZIndex="10"
        HorizontalAlignment="Left"
        VerticalAlignment="Top">
                                    <TextBlock x:Name="CropToastText"
               Foreground="White"
               FontFamily="Tahoma"
               FontSize="9"/>
                                </Border>

                            </Canvas>

                        </Grid>

                    </ScrollViewer>

                </Grid>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          Background="#2A2A2A"
                          HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- SIDEBAR CONTROLLI -->
            <Border Grid.Column="2" Background="#242424" BorderBrush="#333333" BorderThickness="1,0,0,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14,10" Unloaded="StackPanel_Unloaded">
                        <Border Background="#1e1e1e" Height="120" CornerRadius="2">
                            <Canvas x:Name="HistogramCanvas" Width="256" Height="50" Margin="0,0,0,10" Visibility="Visible"/>
                        </Border>
                        <!-- Info file -->
                        <TextBlock Style="{StaticResource SectionTitle}"><Run Language="it-it" Text="File Informations"/></TextBlock>
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="10,8" Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock x:Name="CameraModel" Text="—"
                                           Foreground="#CCCCCC"/>
                                <TextBlock x:Name="FileDetails" Text="—"
                                           Foreground="#666666" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Separator Style="{StaticResource SidebarSeparator}"/>

                        <!-- ─── LUCE ─── -->
                        <TextBlock Style="{StaticResource SectionTitle}"><Run Language="it-it" Text="Light Settings"/></TextBlock>

                        <!-- Esposizione -->
                        <TextBlock Style="{StaticResource SidebarLabel}"><Run Language="it-it" Text="Brightness"/></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="ExposureSlider" Grid.Column="0"
                                    Minimum="-3" Maximum="3" Value="0"
                                    Style="{StaticResource SliderStyle}" ValueChanged="ExposureSlider_ValueChanged"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                                       Text="{Binding Value, ElementName=ExposureSlider, StringFormat=\{0:F1\}}"/>
                        </Grid>

                        <!-- Contrasto -->
                        <TextBlock Style="{StaticResource SidebarLabel}"><Run Language="it-it" Text="Contrast"/></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="ContrastSlider" Grid.Column="0"
                                    Minimum="-100" Maximum="100" Value="0"
                                    Style="{StaticResource SliderStyle}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                                       Text="{Binding Value, ElementName=ContrastSlider, StringFormat=\{0:F0\}}"/>
                        </Grid>

                        <!-- Luci -->
                        <TextBlock Style="{StaticResource SidebarLabel}"><Run Language="it-it" Text="Lights"/></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="HighlightsSlider" Grid.Column="0"
                                    Minimum="-100" Maximum="100" Value="0"
                                    Style="{StaticResource SliderStyle}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                                       Text="{Binding Value, ElementName=HighlightsSlider, StringFormat=\{0:F0\}}"/>
                        </Grid>

                        <!-- Ombre -->
                        <TextBlock Style="{StaticResource SidebarLabel}"><Run Language="it-it" Text="Shadows"/></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="ShadowsSlider" Grid.Column="0"
                                    Minimum="-100" Maximum="100" Value="0"
                                    Style="{StaticResource SliderStyle}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                                       Text="{Binding Value, ElementName=ShadowsSlider, StringFormat=\{0:F0\}}"/>
                        </Grid>

                        <Separator Style="{StaticResource SidebarSeparator}"/>

                        <!-- ─── COLORE ─── -->
                        <TextBlock Text="Colors" Style="{StaticResource SectionTitle}"/>

                        <!-- Temperature Label Row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Label -->
                            <TextBlock Text="Temperature (K)" Style="{StaticResource SidebarLabel}" Margin="0,4,0,10"/>
                            <!-- Spacer -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,7">
                                <!-- Icon 1 -->
                                <ToggleButton Style="{StaticResource SliderButtonStyle}" Width="20" Height="20" Margin="0,0,4,0" Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked">
                                    <Image Source="Icons/wb-camera-mini.png"/>
                                </ToggleButton>
                                <!-- Icon 2 -->
                                <ToggleButton Style="{StaticResource SliderButtonStyle}" Width="20" Height="20" Checked="ToggleButton_Checked_1" Unchecked="ToggleButton_Unchecked_1">
                                    <Image Source="Icons/wb-auto-mini.png" Stretch="Fill"/>
                                </ToggleButton>
                            </StackPanel>
                        </Grid>

                        <!-- Temperature Slider Row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="TempSlider" Grid.Column="0"
            Minimum="2000" Maximum="10000" Value="5500"
            Style="{StaticResource SliderStyle}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
               Text="{Binding Value, ElementName=TempSlider, StringFormat=\{0:F0\}}"/>
                        </Grid>

                        <!-- Tinta -->
                        <TextBlock Text="Tinta" Style="{StaticResource SidebarLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="TintSlider" Grid.Column="0"
                                    Minimum="-100" Maximum="100" Value="0"
                                    Style="{StaticResource SliderStyle}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                                       Text="{Binding Value, ElementName=TintSlider, StringFormat=\{0:F0\}}"/>
                        </Grid>

                        <!-- Saturation -->
                        <TextBlock Text="Saturation" Style="{StaticResource SidebarLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SaturationSlider" Grid.Column="0"
                                    Minimum="-100" Maximum="100" Value="0"
                                    Style="{StaticResource SliderStyle}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                                       Text="{Binding Value, ElementName=SaturationSlider, StringFormat=\{0:F0\}}"/>
                        </Grid>

                        <Separator Style="{StaticResource SidebarSeparator}"/>

                        <!-- ─── LUT ─── -->
                        <TextBlock Text="LUT" Style="{StaticResource SectionTitle}"/>

                        <Border Background="#1E1E1E" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <ComboBox x:Name="LutBox" DropDownOpened="ComboBox_DropDownOpened" DropDownClosed="LutBox_DropDownClosed"/>
                            </StackPanel>

                        </Border>

                        <TextBlock Text="LUT Opacity" Style="{StaticResource SidebarLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="LutIntensitySlider" Grid.Column="0"
                                    Minimum="0" Maximum="100" Value="100"
                                    Style="{StaticResource SliderStyle}" ValueChanged="LutIntensitySlider_ValueChanged_1"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                                       Text="{Binding Value, ElementName=LutIntensitySlider, StringFormat=\{0:F0\}%}"/>
                        </Grid>

                        <Separator Style="{StaticResource SidebarSeparator}"/>

                        <!-- Pulsante Reset -->
                        <Button Content="Reimposta tutto"
                                Margin="0,16,0,8" Height="30"
                                Background="Transparent" Foreground="#666666"
                                BorderBrush="#333333" BorderThickness="1"
                                FontFamily="{DynamicResource Lab.Font.Primary}" FontSize="{DynamicResource Lab.FontSize.Small}"
                                Cursor="Hand"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!-- STATUS BAR                              -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#161616" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Grid.ColumnSpan="4" VerticalAlignment="Bottom">
            <DockPanel Margin="10,0">
                <TextBlock x:Name="ZoomText"
                           Foreground="#555555"
                           FontFamily="{DynamicResource Lab.Font.Primary}" FontSize="{DynamicResource Lab.FontSize.Small}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"><Run Language="it-it" Text="."/></TextBlock>
                <TextBlock x:Name="PixelInfo"
                           Text=""
                           Foreground="#444444"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

    </Grid>
</mah:MetroWindow>