<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">


    <!-- =========================
         FONT FAMILY
    ========================== -->
    <FontFamily x:Key="Lab.Font.Primary">/Fonts/Satoshi-Regular.otf#Satoshi</FontFamily>
    <FontFamily x:Key="Lab.Font.Fallback">Tahoma</FontFamily>
    <FontFamily x:Key="Lab.Font.Code">/Fonts/RedditSansCondensed-Regular.ttf#Reddit Sans Condensed</FontFamily>
    <FontFamily x:Key="Lab.Font.Condensed">/Fonts/RedditSansCondensed-Regular.ttf#Reddit Sans Condensed</FontFamily>
    <sys:Double x:Key="MahApps.Font.Size.Window.Title">12</sys:Double>

    <!-- =========================
         DIMENSIONI & FONT
    ========================== -->
    <sys:Double x:Key="Lab.FontSize.Normal">12</sys:Double>
    <sys:Double x:Key="Lab.FontSize.Small">12</sys:Double>
    <sys:Double x:Key="Lab.FontSize.Large">16</sys:Double>
    <sys:Double x:Key="Lab.Size.SliderHeight">20</sys:Double>
    <sys:Double x:Key="Lab.Size.MenuHeight">28</sys:Double>
    <sys:Double x:Key="Lab.Size.ButtonHeight">26</sys:Double>

    <!-- =========================
         COLORI BASE (Lab Live Dark)
    ========================== -->
    <!-- Background principale -->
    <Color x:Key="Lab.Color.Background">#FF1A1A1A</Color>

    <!-- Superfici e pannelli -->
    <Color x:Key="Lab.Color.Surface">#FF232323</Color>
    <Color x:Key="Lab.Color.SurfaceRaised">#FF2A2A2A</Color>
    <Color x:Key="Lab.Color.SurfaceSunken">#FF141414</Color>

    <!-- Bordi e separatori -->
    <Color x:Key="Lab.Color.Border">#FF0D0D0D</Color>
    <Color x:Key="Lab.Color.BorderLight">#FF3A3A3A</Color>
    <Color x:Key="Lab.Color.Divider">#FF2E2E2E</Color>

    <!-- Testo -->
    <Color x:Key="Lab.Color.Text">#FFCCCCCC</Color>
    <Color x:Key="Lab.Color.TextBright">White</Color>
    <Color x:Key="Lab.Color.TextMuted">#FF7F7F7F</Color>
    <Color x:Key="Lab.Color.TextDisabled">#FF4A4A4A</Color>

    <!-- Accent (arancione Lab) -->
    <Color x:Key="Lab.Color.Accent">#2c3e50</Color>
    <Color x:Key="Lab.Color.AccentHover">#34495e</Color>
    <Color x:Key="Lab.Color.AccentPressed">#2c3e50</Color>

    <!-- Stati interattivi -->
    <Color x:Key="Lab.Color.Hover">#FF2F2F2F</Color>
    <Color x:Key="Lab.Color.Active">#FF363636</Color>
    <Color x:Key="Lab.Color.Selected">#FF404040</Color>

    
    
    
    <!-- =========================
         BRUSHES - Backgrounds
    ========================== -->
    <SolidColorBrush x:Key="Lab.Brush.Background" Color="{StaticResource Lab.Color.Background}"/>
    <SolidColorBrush x:Key="Lab.Brush.Surface" Color="{StaticResource Lab.Color.Surface}"/>
    <SolidColorBrush x:Key="Lab.Brush.SurfaceRaised" Color="{StaticResource Lab.Color.SurfaceRaised}"/>
    <SolidColorBrush x:Key="Lab.Brush.SurfaceSunken" Color="{StaticResource Lab.Color.SurfaceSunken}"/>

    <!-- BRUSHES - Borders -->
    <SolidColorBrush x:Key="Lab.Brush.Border" Color="{StaticResource Lab.Color.Border}"/>
    <SolidColorBrush x:Key="Lab.Brush.BorderLight" Color="{StaticResource Lab.Color.BorderLight}"/>
    <SolidColorBrush x:Key="Lab.Brush.Divider" Color="{StaticResource Lab.Color.Divider}"/>

    <!-- BRUSHES - Text -->
    <SolidColorBrush x:Key="Lab.Brush.Text" Color="{StaticResource Lab.Color.Text}"/>
    <SolidColorBrush x:Key="Lab.Brush.TextBright" Color="{StaticResource Lab.Color.TextBright}"/>
    <SolidColorBrush x:Key="Lab.Brush.TextMuted" Color="{StaticResource Lab.Color.TextMuted}"/>
    <SolidColorBrush x:Key="Lab.Brush.TextDisabled" Color="{StaticResource Lab.Color.TextDisabled}"/>

    <!-- BRUSHES - Accent -->
    <SolidColorBrush x:Key="Lab.Brush.Accent" Color="{StaticResource Lab.Color.Accent}"/>
    <SolidColorBrush x:Key="Lab.Brush.AccentHover" Color="{StaticResource Lab.Color.AccentHover}"/>
    <SolidColorBrush x:Key="Lab.Brush.AccentPressed" Color="{StaticResource Lab.Color.AccentPressed}"/>

    <!-- BRUSHES - Interactive States -->
    <SolidColorBrush x:Key="Lab.Brush.Hover" Color="{StaticResource Lab.Color.Hover}"/>
    <SolidColorBrush x:Key="Lab.Brush.Active" Color="{StaticResource Lab.Color.Active}"/>
    <SolidColorBrush x:Key="Lab.Brush.Selected" Color="{StaticResource Lab.Color.Selected}"/>

    <!-- =========================
         OVERRIDE MAHAPPS
    ========================== -->
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource Lab.Color.Accent}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource Lab.Color.AccentHover}"/>
    <SolidColorBrush x:Key="IdealForegroundColorBrush" Color="{StaticResource Lab.Color.TextBright}"/>

    <SolidColorBrush x:Key="MahApps.Brushes.ThemeBackground" Color="{StaticResource Lab.Color.Background}"/>
    <SolidColorBrush x:Key="MahApps.Brushes.ControlBackground" Color="{StaticResource Lab.Color.Surface}"/>
    <SolidColorBrush x:Key="MahApps.Brushes.WindowTitle" Color="{StaticResource Lab.Color.Background}"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
    </Style>
    
    <!-- =========================
         MENU
    ========================== -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="Height" Value="{DynamicResource Lab.Size.MenuHeight}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
        <Setter Property="Padding" Value="8,4"/>

        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.Hover}"/>
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextBright}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextDisabled}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         BUTTON
    ========================== -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.SurfaceRaised}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.BorderLight}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Small}"/>
        <Setter Property="Height" Value="{DynamicResource Lab.Size.ButtonHeight}"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.Hover}"/>
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextBright}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.SurfaceSunken}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Accent}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextDisabled}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Border}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         BUTTON ACCENT (stile per bottoni primari)
    ========================== -->
    <Style x:Key="Lab.Button.Accent" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextBright}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Accent}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.AccentHover}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.AccentHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.AccentPressed}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.AccentPressed}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         TEXT
    ========================== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.SurfaceSunken}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.BorderLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Lab.Brush.Accent}"/>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Accent}"/>
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Accent}"/>
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.Surface}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextDisabled}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ParameterBox.xaml -->
    <Style x:Key="ParameterStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.SurfaceSunken}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.BorderLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Small}"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Lab.Brush.Accent}"/>
    </Style>


    <!-- =========================
         LABEL
    ========================== -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
    </Style>

    <!-- =========================
         SLIDER
    ========================== -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.BorderLight}"/>
        <Setter Property="Height" Value="{DynamicResource Lab.Size.SliderHeight}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- =========================
         CHECKBOX
    ========================== -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>

        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextDisabled}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Lab.ComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.SurfaceRaised}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.BorderLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="2"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ToggleButton.Background>
                                <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}"/>
                            </ToggleButton.Background>
                            <ToggleButton.BorderBrush>
                                <Binding Path="BorderBrush" RelativeSource="{RelativeSource TemplatedParent}"/>
                            </ToggleButton.BorderBrush>
                            <ToggleButton.BorderThickness>
                                <Binding Path="BorderThickness" RelativeSource="{RelativeSource TemplatedParent}"/>
                            </ToggleButton.BorderThickness>
                        </ToggleButton>

                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>

                        <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False">
                            <Border Background="{DynamicResource Lab.Brush.SurfaceRaised}"
                                BorderBrush="{DynamicResource Lab.Brush.BorderLight}"
                                BorderThickness="1"
                                MinWidth="{TemplateBinding ActualWidth}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lab.ComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.Hover}"/>
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextBright}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.Selected}"/>
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextBright}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         LISTBOX
    ========================== -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.SurfaceSunken}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.BorderLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="Padding" Value="8,4"/>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.Hover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.Selected}"/>
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextBright}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         SCROLLBAR
    ========================== -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Border}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.SurfaceRaised}"/>

        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="12"/>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="12"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         TABCONTROL
    ========================== -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextMuted}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
        <Setter Property="Padding" Value="12,6"/>

        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Lab.Brush.SurfaceRaised}"/>
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextBright}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         GROUPBOX
    ========================== -->
    <Style TargetType="GroupBox">
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.BorderLight}"/>
        <Setter Property="BorderThickness" Value="0.3"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.Text}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Normal}"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>

    <!-- =========================
         STATUSBAR
    ========================== -->
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource Lab.Brush.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Lab.Brush.TextMuted}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Lab.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="FontFamily" Value="{DynamicResource Lab.Font.Primary}"/>
        <Setter Property="FontSize" Value="{DynamicResource Lab.FontSize.Small}"/>
    </Style>

</ResourceDictionary>
