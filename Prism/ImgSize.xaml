<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Prism"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="Prism.ImgSize"
    mc:Ignorable="d"
    Title="Image Size"
    Height="254"
    Width="300"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource Lab.Brush.Background}"
    Icon="/export0.png">

    <Grid Margin="20,20,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Sezione dimensioni -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>

            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <!-- Bottoni -->
        </Grid.RowDefinitions>

        <!-- ── DIMENSIONI ORIGINALI ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Original: "
               Foreground="#555555"
               FontSize="10"
               VerticalAlignment="Center"/>
            <TextBlock x:Name="lblOriginalWidth"
               Text=""
               Foreground="#666666"
               FontSize="10"
               VerticalAlignment="Center"/>
            <TextBlock Text=" × "
               Foreground="#555555"
               FontSize="10"
               VerticalAlignment="Center"/>
            <TextBlock x:Name="lblOriginalHeight"
               Text=""
               Foreground="#666666"
               FontSize="10"
               VerticalAlignment="Center"/>
            <TextBlock Text=" px"
               Foreground="#444444"
               FontSize="10"
               VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── DIMENSIONI ── -->
        <Border Grid.Row="2"
                Background="#1E1E1E"
                CornerRadius="4"
                Padding="12,10">
            <Grid Margin="20,20,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Label originale -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Border dimensioni -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Bottoni -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <!-- spazio catena -->
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>

                <!-- Width -->
                <Label Grid.Row="0" Grid.Column="0"
                       Content="Width:"
                       Foreground="#888888"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Padding="0"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         x:Name="txtWidth"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         Text=""
                         FontSize="12" Margin="0,0,19,0"/>

                <!-- Icona catena (span su 2 righe) -->
                <Border Grid.Row="0" Grid.Column="3"
                        Grid.RowSpan="3"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>

                <!-- Height -->
                <Label Grid.Row="2" Grid.Column="0"
                       Content="Height:"
                       Foreground="#888888"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Padding="0"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         x:Name="txtHeight"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         Text=""
                         FontSize="12" Margin="0,0,19,0"/>
                <ToggleButton IsChecked="false" Padding="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="101,16,7,16" Grid.RowSpan="3" Background="{x:Null}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <Image Source="/unchain.png" Width="16" Height="16"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Image Source="/chain1.png" Width="16" Height="16"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </Grid>
        </Border>


        <!-- ── BOTTONI ── -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="90"
                    Height="26"
                    Margin="0,0,8,0"/>
            <Button x:Name="btnExport"
                    Content="Resize"
                    Width="90"
                    Height="26"
                    Style="{DynamicResource Lab.Button.Accent}"/>
        </StackPanel>

    </Grid>
</Window>